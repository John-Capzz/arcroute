# ArcRoute Backend Environment Variables

# Server
PORT=3002
NODE_ENV=development

# Circle App Kit
CIRCLE_APP_KIT_API_KEY=your_circle_api_key_here
CIRCLE_APP_KIT_CLIENT_ID=your_circle_client_id_here

# RPC Endpoints (use public testnets or Alchemy/Infura)
ETH_SEPOLIA_RPC=https://rpc.sepolia.org
BNB_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545
BASE_SEPOLIA_RPC=https://sepolia.base.org
ARC_TESTNET_RPC=https://rpc.arc-testnet.circle.com

# Database (SQLite path)
DB_PATH=./arcroute.db

# Fee configuration
FEE_PERCENT=0.3
